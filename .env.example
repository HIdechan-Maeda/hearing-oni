# Supabase（ブラウザ用。Next.js から使用）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 新規登録を許可する学外メール（移行用・任意）。本番は Supabase の signup_allowlist を推奨。
# 例: NEXT_PUBLIC_RONIN_ALLOWED_EMAILS=ronin1@gmail.com,student@example.com
# NEXT_PUBLIC_RONIN_ALLOWED_EMAILS=

# サーバー専用（/api/signup/check で学外メールを DB と照合）。絶対に NEXT_PUBLIC にしないこと。
# Supabase Dashboard → Project Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# マイグレーション用（npm run db:migrate で使用）
# Supabase Dashboard → Project Settings → Database → Connection string (URI)
# [YOUR-PASSWORD] を実際の DB パスワードに置き換える
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
